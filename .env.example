# Core server settings
PROJECT_NAME=AI Dev Agent Orchestrator
VERSION=0.1.0
HOST=0.0.0.0
PORT=8080

# Database
# Default is derived from app/config.py as an absolute project-root path:
# sqlite:////path/to/orchestrator/orchestrator.db
# Leave unset unless you intentionally use another database.
# DATABASE_URL=

# Auth
# Generate your own secret for real use:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# Comma-separated admin emails. Set this before adding extra local/test users.
ADMIN_EMAILS=

# OpenClaw integration
# Use the OpenClaw gateway port, not the LLM-only port.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:8000
OPENCLAW_API_KEY=
OPENCLAW_CLI_PATH=
OPENCLAW_CLI_ARGS=

# Agent runtime
AGENT_BACKEND=local_openclaw
AGENT_MODEL=local
# auto_publish_all, hold_nontrivial, or hold_all
WORKSPACE_REVIEW_POLICY=hold_nontrivial

# Soft-deleted projects remain hidden from the dashboard and can be purged
# after this many days. Leave unset to use the app default, currently 30.
# SOFT_DELETE_RETENTION_DAYS=30

PLANNING_REPAIR_ENABLED=True
PLANNING_REPAIR_BASE_URL=http://ai-gateway:8000/v1
PLANNING_REPAIR_MODEL=qwen-local
PLANNING_REPAIR_API_KEY=
PLANNING_REPAIR_DISABLE_THINKING=True
PLANNING_REPAIR_TIMEOUT_SECONDS=90
JUDGE_AGENT_ENABLED=False
TRACE_EXPORTER_BACKEND=local_json
LANGFUSE_ENABLED=False

# Mobile/OpenClaw bridge
MOBILE_GATEWAY_API_KEY=change-me-shared-secret
MOBILE_BASE_URL=http://127.0.0.1:8080/api/v1

# Runtime mode
DEMO_MODE=False
ALLOW_TEST_KEYPAIR_ENDPOINT=False
INLINE_PLANNING=False

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# GitHub integration (optional)
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_WEBHOOK_SECRET=

# Frontend
VITE_API_URL=/api/v1
# Leave empty to follow the API host automatically.
# Set to "<host>:<port>" only when WebSockets should use a different backend target.
VITE_API_WS_HOST=

# Optional startup convenience for start_all.sh health checks
LOCALHOST=127.0.0.1

# Qdrant + Embeddings
# EMBEDDING_PROVIDER: "auto" | "openai" | "ollama"
# "auto" uses OpenAI when OPENAI_API_KEY is set, else falls back to Ollama.
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# 0 = auto (768 for ollama/nomic-embed-text, 1536 for openai)
EMBEDDING_DIM=0
# Leave OPENAI_API_KEY empty to use Ollama. Set it to switch to OpenAI.
OPENAI_API_KEY=
