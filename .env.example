# Core server settings
PROJECT_NAME=AI Dev Agent Orchestrator
VERSION=0.1.0
HOST=0.0.0.0
PORT=8080

# Database
DATABASE_URL=sqlite:///./orchestrator.db

# Auth
# Generate your own secret for real use:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=15
AUTH_RATE_LIMIT_WINDOW_SECONDS=60
AUTH_RATE_LIMIT_MAX_ATTEMPTS=5

# OpenClaw integration
# Use the OpenClaw gateway port, not the LLM-only port.
OPENCLAW_GATEWAY_URL=http://127.0.0.1:8000
OPENCLAW_API_KEY=
OPENCLAW_CLI_PATH=
OPENCLAW_CLI_ARGS=

# Mobile/OpenClaw bridge
MOBILE_GATEWAY_API_KEY=change-me-shared-secret
ORCHESTRATOR_MOBILE_BASE_URL=http://127.0.0.1:8080/api/v1

# Runtime mode
DEMO_MODE=False
ALLOW_TEST_KEYPAIR_ENDPOINT=False
ORCHESTRATOR_FORCE_INLINE_PLANNING=False

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# GitHub integration (optional)
GITHUB_TOKEN=
GITHUB_USERNAME=
GITHUB_WEBHOOK_SECRET=

# Frontend
VITE_API_URL=/api/v1
# Leave empty to follow the API host automatically.
# Set to "<host>:<port>" only when WebSockets should use a different backend target.
VITE_API_WS_HOST=

# Optional startup convenience for start_all.sh health checks
LOCALHOST=127.0.0.1
